# --- server ---
HTTP_ADDR=:3000
ENV=development
LOG_LEVEL=info

# --- postgres ---
DATABASE_URL=postgres://getoken:getoken@localhost:5432/getoken?sslmode=disable

# --- redis ---
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# --- jwt ---
JWT_SECRET=please-change-me-to-a-long-random-string
JWT_TTL_HOURS=72

# --- initial admin (created on first boot when users table is empty) ---
ADMIN_EMAIL=admin@getoken.dev
ADMIN_PASSWORD=Getoken123!
ADMIN_USERNAME=Admin

# --- smtp (optional, leave blank to disable email features) ---
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# --- registration ---
REGISTER_ENABLED=true
REGISTER_INVITE_REQUIRED=false
REGISTER_EMAIL_CODE_REQUIRED=true

# --- cors ---
CORS_ORIGINS=http://localhost:5173

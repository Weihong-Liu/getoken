# --- server ---
HTTP_ADDR=:3000
ENV=development
LOG_LEVEL=info

# --- postgres ---
DATABASE_URL=postgres://getoken:getoken@localhost:5432/getoken?sslmode=disable

# --- redis ---
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# --- jwt ---
JWT_SECRET=please-change-me-to-a-long-random-string
JWT_TTL_HOURS=72

# --- initial admin (created on first boot when users table is empty) ---
ADMIN_EMAIL=admin@getoken.dev
ADMIN_PASSWORD=Getoken123!
ADMIN_USERNAME=Admin

# --- mail provider (transactional email; verification codes, password reset) ---
# Pick one:
#   resend  → POST api.resend.com/emails using RESEND_API_KEY (recommended for MVP)
#   smtp    → any SMTP server using SMTP_* below (Brevo / Postmark / self-hosted Postal …)
#   <blank> → no-op mode (codes only logged; intended for local dev)
MAIL_PROVIDER=
RESEND_API_KEY=

# --- smtp (used when MAIL_PROVIDER=smtp) ---
# Port 465 is implicit TLS; port 587 with SMTP_USE_TLS=false uses STARTTLS.
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# --- registration ---
REGISTER_ENABLED=true
REGISTER_INVITE_REQUIRED=false
REGISTER_EMAIL_CODE_REQUIRED=true

# --- github oauth (optional; leave blank to disable "Login with GitHub") ---
# 1. github.com/settings/developers → New OAuth App
# 2. Homepage URL: https://api.getoken.tech
# 3. Authorization callback URL: https://api.getoken.tech/auth/github/callback
# 4. After creation, paste client_id + client_secret here.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=https://api.getoken.tech/auth/github/callback

# --- cors ---
CORS_ORIGINS=http://localhost:5173
